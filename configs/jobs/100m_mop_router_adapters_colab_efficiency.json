{
  "kind": "gpu_train",
  "metadata": {
    "description": "Colab MoP router/adapters-only efficiency profile."
  },
  "payload": {
    "activation_checkpointing": true,
    "allow_tf32": true,
    "device": "auto",
    "d_model": 768,
    "enable_amp": true,
    "eval_every_steps": 50,
    "fast_adapter_names": [
      "coding",
      "debugging",
      "repair"
    ],
    "gradient_accumulation_steps": 8,
    "max_eval_examples": 512,
    "max_seq_len": 1024,
    "max_steps": 200,
    "max_train_examples": 10000,
    "metadata": {
      "description": "MoP 100M Colab profile with only router/adapters trainable where present.",
      "parameter_count": 100000000,
      "profile": "100m_mop_router_adapters_colab_efficiency",
      "target_gpu_memory_gb": 24
    },
    "micro_batch_size": 1,
    "model_type": "mop_oracle",
    "n_heads": 12,
    "n_layers": 12,
    "name": "100m_mop_router_adapters_colab_efficiency",
    "precision": "auto",
    "require_device_available": false,
    "save_every_steps": 100,
    "target_modules": [
      "coding",
      "debugging",
      "repair"
    ],
    "trainable_policy_mode": "router_adapters_only",
    "use_fast_adapters": true
  },
  "version": "1"
}
