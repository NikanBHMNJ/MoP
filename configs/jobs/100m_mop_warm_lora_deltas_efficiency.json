{
  "kind": "gpu_train",
  "metadata": {
    "description": "Warm-started low-rank MoP delta profile for sparse quality recovery."
  },
  "payload": {
    "activation_checkpointing": true,
    "allow_tf32": true,
    "always_include_core": false,
    "base_checkpoint_path": "REPLACE_WITH_100M_MOP_FULL_CHECKPOINT_OR_RUN_ID",
    "device": "auto",
    "d_model": 768,
    "enable_amp": true,
    "eval_batches": 2,
