    "n_heads": 12,
    "n_layers": 12,
    "precision": "auto",
    "require_device_available": false,
    "resume_from_checkpoint": "REPLACE_WITH_100M_MOP_FULL_CHECKPOINT_OR_RUN_ID",
    "resume_model_only": true,
    "run_generation_eval": true,
    "save_every_steps": 500,
    "save_trainable_only_checkpoints": true,
    "scheduler": "cosine",
    "target_modules": [
      "coding",
      "debugging",
      "repair"
    ],
    "trainable_policy_mode": "adapters_norm_head",
