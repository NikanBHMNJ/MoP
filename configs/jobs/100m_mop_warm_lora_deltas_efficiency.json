    "fast_adapter_names": [
      "coding",
      "debugging",
      "repair"
    ],
    "generation_eval_examples": 2,
    "generation_max_new_tokens": 32,
    "gradient_accumulation_steps": 8,
    "learning_rate": 0.0005,
    "log_every_steps": 25,
    "lora_rank": 8,
    "lora_target_modules": [
      "coding",
      "debugging",
      "repair"
    ],
    "max_eval_examples": 512,
    "max_seq_len": 1024,
    "max_steps": 2000,
    "max_train_examples": 10000,
    "metadata": {
      "description": "Load a learned base and train adapters, norm/head, and routed low-rank deltas.",
